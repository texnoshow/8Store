<SettingsFlyout
    x:Class="_8Store__beta_.StoreSettings"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Настройки"
    HeaderBackground="#FF008A00"
    IconSource="ms-appx:///Assets/SmallLogo.png">

    <StackPanel VerticalAlignment="Top" Margin="20">
        <TextBlock Text="Путь для загрузок" 
                   FontSize="18" 
                   FontWeight="SemiBold" 
                   Foreground="Black"/>

        <TextBlock Text="Выберите папку, в которую приложение будет скачивать установочные файлы (.appx)." 
                   FontSize="14" 
                   TextWrapping="Wrap" 
                   Margin="0,10,0,20" 
                   Foreground="#FF444444"/>

        <Button x:Name="ChangeFolderButton" 
                Content="Сменить папку" 
                Click="ChangeFolder_Click" 
                HorizontalAlignment="Stretch" 
                Height="40"
                Background="#FF008A00" 
                Foreground="White"/>

        <Border Margin="0,20,0,0" BorderBrush="#FFCCCCCC" BorderThickness="0,1,0,0" Padding="0,20,0,0">
            <StackPanel>
                <TextBlock Text="О приложении" 
                           FontSize="18" 
                           FontWeight="SemiBold" 
                           Foreground="Black"/>
                <TextBlock Text="8Store beta v1.0" 
                           FontSize="14" 
                           Margin="0,5,0,0" 
                           Foreground="Gray"/>
                <TextBlock Text="Создано для Windows 8.1 и 10." 
                           FontSize="14" 
                           Margin="0,5,0,0" 
                           Foreground="Gray"/>
            </StackPanel>
        </Border>
    </StackPanel>
</SettingsFlyout>